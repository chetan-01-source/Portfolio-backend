APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://chetanmarathe.dev
OPENROUTER_APP_NAME=CHET.ai
LLM_CHEAP_MODEL=google/gemini-2.5-flash
LLM_STRONG_MODEL=anthropic/claude-haiku-4.5
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIM=1536

# MongoDB
MONGODB_URI=mongodb://dev:dev@localhost:27017/?authSource=admin
MONGODB_DB=chet_ai

# Redis
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_THRESHOLD=0.93
SEMANTIC_CACHE_TTL_SECONDS=86400
EXACT_CACHE_TTL_SECONDS=604800

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=chet_kb

# Reranker (BGE sidecar). Leave empty to disable rerank.
RERANKER_URL=
RERANKER_TOP_N=4

# Ingestion API. Leave INGEST_API_KEY empty for local/dev; set it in prod.
INGEST_API_KEY=
INGEST_DEFAULT_MAX_PAGES=10
INGEST_DEFAULT_MAX_DEPTH=1
INGEST_FETCH_TIMEOUT_SECONDS=15
INGEST_MAX_URL_BYTES=2000000

# SendGrid Web API (email goes TO the lead)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_TEMPLATE_ID=d-8ef38ee86ac8492aaba9413a8e8be01b
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_NAME=CHET.ai
# Set to eu only for an EU-pinned SendGrid subuser; otherwise leave empty.
SENDGRID_DATA_RESIDENCY=

# Chetan's identity (used in lead-facing emails)
CHETAN_EMAIL=chetanmarathe0412@gmail.com
CHETAN_PHONE=8999431754
INCLUDE_PHONE_IN_EMAIL=false
CHETAN_RESUME_URL=https://chetanmarathe.dev/resume.pdf
CHETAN_RESUME_ATTACHMENT_PATH=data/resume.pdf
CHETAN_PORTFOLIO_URL=https://chetanmarathe.dev
CHETAN_LINKEDIN_URL=https://linkedin.com/in/chetanmarathe
CHETAN_GITHUB_URL=https://github.com/chetanmarathe
CHETAN_LEETCODE_URL=https://leetcode.com/chetanmarathe

# Eval / observability
EVAL_SAMPLE_RATE=0.01

# Internal notification on every lead capture
NOTIFY_CHETAN_ON_LEAD=true
